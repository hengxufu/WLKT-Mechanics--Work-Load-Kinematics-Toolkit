{
  "name": "wlkt-mechanics",
  "version": "1.0.7",
  "description": "Offline mechanics of materials and structural analysis toolkit for local teaching workflows.",
  "author": "WLKT Mechanics Contributors",
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:dirty": "vite build",
    "build:pages": "vite build",
    "app:build": "vite build",
    "app:preview": "vite preview --host 127.0.0.1 --port 4173",
    "desktop:build": "node scripts/build-desktop.mjs",
    "desktop:dev": "npm run desktop:build && electron electron/main.cjs",
    "desktop:stage": "node scripts/prepare-desktop-app.mjs",
    "desktop:pack": "npm run desktop:build && npm run desktop:stage && node scripts/run-electron-builder.mjs --projectDir .desktop-app --dir",
    "desktop:dist": "npm run desktop:build && npm run desktop:stage && node scripts/run-electron-builder.mjs --projectDir .desktop-app",
    "desktop:dist:win": "npm run desktop:build && npm run desktop:stage && node scripts/run-electron-builder.mjs --projectDir .desktop-app --win nsis",
    "package:offline": "node scripts/package-offline.mjs",
    "release:checksums": "node scripts/create-checksums.mjs",
    "serve:dist": "node scripts/serve-dist.mjs dist 4173",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@imengyu/vue3-context-menu": "^1.5.2",
    "@intlify/unplugin-vue-i18n": "^11.0.3",
    "@tweakpane/plugin-essentials": "^0.2.1",
    "@types/js-quantities": "^1.6.6",
    "@vueuse/components": "^14.1.0",
    "@vueuse/core": "^14.1.0",
    "fast-xml-parser": "^5.3.3",
    "floating-vue": "^5.2.2",
    "jenesius-vue-modal": "^1.11.9",
    "js-quantities": "^1.8.0",
    "language-icons": "^0.3.0",
    "mathjs": "^15.1.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "ts-fem": "github:janvorisek/ts-fem#b18694f42119de46c91cb37143896ca69e54d5a3",
    "tweakpane": "^4.0.5",
    "v-onboarding": "^2.9.0",
    "v-tweakpane": "^0.3.2",
    "vue": "^3.5.26",
    "vue-draggable-resizable": "^3.0.0",
    "vue-i18n": "^11.2.2",
    "vue-router": "^4.6.4",
    "vuetify": "^3.11.4"
  },
  "build": {
    "appId": "cn.buaa.wlkt.mechanics",
    "productName": "WLKT Mechanics 材料力学求解器",
    "copyright": "Copyright © 2026 WLKT Mechanics",
    "directories": {
      "output": "release/desktop",
      "buildResources": "public"
    },
    "files": [
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "electron",
        "to": "electron",
        "filter": [
          "**/*"
        ]
      },
      "package.json",
      {
        "from": "LICENSE",
        "to": "LICENSE"
      },
      {
        "from": "README.md",
        "to": "README.md"
      },
      {
        "from": "docs/windows-installer.md",
        "to": "docs/windows-installer.md"
      }
    ],
    "extraMetadata": {
      "main": "electron/main.cjs",
      "dependencies": {},
      "devDependencies": {}
    },
    "asar": true,
    "compression": "maximum",
    "npmRebuild": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon.ico",
      "requestedExecutionLevel": "highestAvailable",
      "signAndEditExecutable": true,
      "verifyUpdateCodeSignature": true,
      "artifactName": "WLKT-Mechanics-${version}-${arch}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WLKT Mechanics 材料力学求解器",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@mdi/font": "^7.4.47",
    "@types/node": "^25.0.3",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/ui": "^4.0.16",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^16.5.0",
    "happy-dom": "^20.0.11",
    "markdown-it-implicit-figures": "^0.12.0",
    "markdown-it-katex": "^2.0.3",
    "prettier": "^3.7.4",
    "prettier-eslint": "^16.4.2",
    "sass": "^1.97.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.3.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vuetify": "^2.1.2",
    "vitepress": "^2.0.0-alpha.15",
    "vitest": "^4.0.16",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.8"
  }
}
