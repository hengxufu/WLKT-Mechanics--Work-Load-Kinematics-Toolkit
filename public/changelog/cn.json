    {
      "version": "1.0.4",
      "title": "自由点尺寸标注",
      "date": "2026年3月19日",
      "highlights": [
        "尺寸标注可以从屏幕上的任意点开始或结束，不再需要创建无用有限元节点。",
        "尺寸端点会显示捕捉点，并可直接拖拽。",
        "创建和拖拽过程中的端点捕捉更可靠，支持自由点和节点捕捉。",
        "尺寸标注的右键菜单支持翻转端点顺序，并可直接编辑端点坐标。"
      ],
      "media": [
        {
          "src": "/changelog/media/freedimpoints.gif",
          "alt": "自由点尺寸标注演示",
          "caption": "自由点尺寸标注演示"
        }
      ]
    },
